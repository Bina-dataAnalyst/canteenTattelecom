// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // Теперь это снова работает!
}

model Canteen {
  id        String   @id @default(cuid())
  name      String
  address   String?
  dishes    Dish[]
  orders    Order[]
}

model Dish {
  id           String   @id @default(cuid())
  name         String   @unique
  composition  String?
  category     Category @relation(fields: [categoryId], references: [id])
  categoryId   String
  price        Float
  calories     Int?     // Опционально, как ты и просил
  proteins     Float?
  fats         Float?
  carbs        Float?
  weight       String?
  note         String?
  image        String?
  stock        Int      @default(0) // Для "Осталось мало"
  canteen      Canteen  @relation(fields: [canteenId], references: [id])
  canteenId    String
  isAvailable  Boolean  @default(true)

  favoritedBy  Favorite[]
}

model User {
  id           String     @id @default(cuid()) // ID из Блиц
  email        String     @unique
  name         String?
  calorieLimit Int        @default(2000)
  favorites    Favorite[]
  orders       Order[]
}

model Favorite {
  user     User @relation(fields: [userId], references: [id])
  userId   String
  dish     Dish @relation(fields: [dishId], references: [id])
  dishId   String

  @@id([userId, dishId]) // Составной ключ
}

model Order {
  id         String      @id @default(cuid())
  user       User        @relation(fields: [userId], references: [id])
  userId     String
  canteen    Canteen     @relation(fields: [canteenId], references: [id])
  canteenId  String
  status     OrderStatus @default(PENDING) // PENDING, READY, COMPLETED, CANCELLED
  totalPrice Float
  items      Json        // Снапшот блюд на момент заказа
  createdAt  DateTime    @default(now())
}

enum OrderStatus {
  PENDING
  READY
  COMPLETED
  CANCELLED
}

model Category {
  id     String @id @default(cuid())
  name   String @unique
  dishes Dish[]
}
